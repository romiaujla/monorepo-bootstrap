{
  "name": "@repo/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/server.ts",
    "lint": "eslint src --config eslint.config.mjs",
    "test": "pnpm test:unit",
    "test:e2e": "echo \"No e2e tests configured for @repo/api\"",
    "test:integration": "echo \"No integration tests configured for @repo/api\"",
    "test:unit": "echo \"No unit tests configured for @repo/api\"",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@repo/types": "workspace:*",
    "express": "^5.1.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@repo/tsconfig": "workspace:*",
    "@types/express": "^5.0.3",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}

