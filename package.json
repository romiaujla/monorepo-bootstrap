{
  "name": "monorep-bootstrap",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@10.12.1",
  "engines": {
    "node": ">=22.16.0",
    "pnpm": ">=10.12.1"
  },
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "turbo lint",
    "local:postgres:logs": "node ./scripts/manage-local-postgres.mjs logs",
    "local:postgres:remove": "node ./scripts/manage-local-postgres.mjs remove",
    "local:postgres:setup": "node ./scripts/local-postgres-setup.mjs",
    "local:postgres:start": "node ./scripts/manage-local-postgres.mjs start",
    "local:postgres:status": "node ./scripts/manage-local-postgres.mjs status",
    "local:postgres:stop": "node ./scripts/manage-local-postgres.mjs stop",
    "specify.audit": "node ./scripts/specify-audit.mjs",
    "specify.drift": "node ./scripts/specify-drift.mjs",
    "test": "turbo test",
    "test:e2e": "turbo test:e2e",
    "test:integration": "turbo test:integration",
    "test:unit": "turbo test:unit",
    "typecheck": "turbo typecheck"
  },
  "devDependencies": {
    "@eslint/js": "^9.25.0",
    "@types/node": "^22.15.17",
    "@typescript-eslint/eslint-plugin": "^8.30.1",
    "@typescript-eslint/parser": "^8.30.1",
    "eslint": "^9.25.0",
    "eslint-config-prettier": "^10.1.2",
    "globals": "^16.0.0",
    "prettier": "^3.5.3",
    "turbo": "^2.5.0",
    "typescript": "^5.8.3",
    "zod": "^3.24.3"
  }
}
